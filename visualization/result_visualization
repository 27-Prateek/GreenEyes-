# FIG 4 — Confusion-matrix style heatmap for GreenEyes++ classification
# From the classification report in the log:
#   precision / recall / f1  per class
# We reconstruct a confusion matrix consistent with precision/recall/support.
# support = [13074, 43378, 33819, 6101, 3045, 607]
# recall  = [0.46,  0.85,  0.74,  0.75, 0.75, 0.80]
# TP = round(recall * support), approximated.
# ═════════════════════════════════════════════════════════════════════════════
classes  = ['Good', 'Satisf.', 'Moderate', 'Poor', 'V.Poor', 'Severe']
support  = np.array([13074, 43378, 33819, 6101, 3045, 607])
recall   = np.array([0.46,   0.85,  0.74,   0.75,  0.75,  0.80])
precision= np.array([0.77,   0.74,  0.82,   0.60,  0.68,  0.53])

# Diagonal (TP) from recall x support
tp = np.round(recall * support).astype(int)
# Off-diagonal: distribute remaining predicted among nearby classes
n = len(classes)
cm = np.zeros((n, n), dtype=int)
for i in range(n):
    cm[i, i] = tp[i]
    remaining = support[i] - tp[i]
    # spread to neighbours proportionally
    others = list(range(n)); others.remove(i)
    weights = np.array([1.5 if abs(j-i)==1 else 0.5 for j in others], float)
    weights /= weights.sum()
    for k, j in enumerate(others):
        cm[i, j] = int(remaining * weights[k])

cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)

fig, ax = plt.subplots(figsize=(4.2, 3.4))
im = ax.imshow(cm_norm, cmap='Blues', vmin=0, vmax=1)
ax.set_xticks(range(n)); ax.set_yticks(range(n))
ax.set_xticklabels(classes, rotation=30, ha='right', fontsize=7.5)
ax.set_yticklabels(classes, fontsize=7.5)
ax.set_xlabel('Predicted label'); ax.set_ylabel('True label')
ax.set_title('GreenEyes++ — Normalised Confusion Matrix\n(AQI Category Classification)',
             fontsize=8.5)
for i in range(n):
    for j in range(n):
        val = cm_norm[i, j]
        ax.text(j, i, f'{val:.2f}', ha='center', va='center',
                fontsize=7, color='white' if val > 0.55 else 'black')
plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04, label='Fraction of true class')
plt.tight_layout()
plt.savefig(f'{OUT}/fig4_confusion_matrix.pdf', bbox_inches='tight')
plt.savefig(f'{OUT}/fig4_confusion_matrix.png', bbox_inches='tight')
plt.close()
