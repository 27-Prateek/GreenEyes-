# FIG 7 — Synthetic forecast ribbon: GreenEyes++ with conformal intervals
# Illustrative 72-h forecast window, consistent with actual quantiles
# t+1h ±33.33, t+24h ±64.85, t+72h ±100.48
# ═════════════════════════════════════════════════════════════════════════════
np.random.seed(42)
T      = 168  # input window
future = 72
t_in   = np.arange(-T, 0)
t_fut  = np.arange(0, future+1)

# A plausible AQI history (moderate-to-poor Indian city)
base = 150 + 40*np.sin(np.linspace(0, 2*np.pi, T)) + np.random.randn(T)*8
# Future: gradual improvement
future_vals = np.linspace(base[-1], base[-1]*0.55, future+1) + np.random.randn(future+1)*5

# Point prediction = future_vals; conformal interval grows with horizon
q1, q24, q72 = 33.33, 64.85, 100.48
q_interp = q1 + (q72 - q1) * np.linspace(0, 1, future+1)

fig, ax = plt.subplots(figsize=(6.0, 2.8))
ax.plot(t_in,  base,        color=GREY,  lw=1.3, label='Input window (168h)')
ax.plot(t_fut, future_vals, color=BLUE,  lw=1.8, label='GreenEyes++ forecast')
ax.fill_between(t_fut,
                future_vals - q_interp,
                future_vals + q_interp,
                color=BLUE, alpha=0.18, label='90% conformal interval')
# Mark the three horizon points
for h, q, lab in [(1,q1,'t+1h'), (24,q24,'t+24h'), (72,q72,'t+72h')]:
    ax.errorbar(h, future_vals[h], yerr=q,
                fmt='D', color=RED, markersize=5, capsize=4,
                label=f'{lab} ±{q:.0f}' if h==1 else None,
                zorder=5)
    ax.annotate(f'±{q:.0f}', xy=(h, future_vals[h]+q+5),
                ha='center', fontsize=7, color=RED)

ax.axvline(0, color='black', lw=0.8, ls='--', label='Prediction start')
ax.set_xlabel('Hours (0 = forecast start)'); ax.set_ylabel('AQI')
ax.set_title('Multi-Horizon AQI Forecast with 90% Conformal Intervals',
             fontsize=9, fontweight='bold')
ax.legend(loc='upper right', fontsize=7)
ax.set_xlim(-T, future+2)
plt.tight_layout()
